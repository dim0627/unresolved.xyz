{
  "name": "unresolved.xyz",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check ./apps ./packages && markdownlint-cli2",
    "lint:fix": "biome check ./apps ./packages --write --unsafe && markdownlint-cli2 --fix",
    "syncpack:fix": "syncpack fix",
    "syncpack:format": "syncpack format",
    "syncpack:lint": "syncpack lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "lefthook": "^2.1.9",
    "markdownlint-cli2": "^0.23.0",
    "syncpack": "15.3.2",
    "turbo": "^2.10.3"
  },
  "engines": {
    "node": ">=18.10.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ],
    "overrides": {
      "axios": "1.13.5"
    }
  }
}
